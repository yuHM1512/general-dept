APP_NAME="rcp-salary-audit"
APP_ENV="dev"
LOG_LEVEL="INFO"

# Web server
HOST="0.0.0.0"
PORT=8012

# Postgres (fill these in)
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/rcp"
DB_CONNECT_TIMEOUT=5

# App behavior
TARGET_SALARY_VND=5600000
CREATE_TABLES_ON_STARTUP=true
ALLOW_LOCAL_INGEST=false

# Optional: default Excel path for local ingest
DEFAULT_EXCEL_PATH="Du lieu luong RCP T1-T3-2026.xlsx"
